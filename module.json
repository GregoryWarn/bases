{
  "id": "bases",
  "title": "Bugbear's Assign Status Effects Sorter",
  "description": "A system-agnostic Foundry VTT module that adds sorting and improves visibility in the Assign Status Effects HUD!",
  "version": "13.351.3.2",
  "compatibility": {
    "minimum": "13",
    "verified": "13.351"
  },
  "authors": [
    {
      "name": "thatlonelybugbear",
      "url": "https://github.com/thatlonelybugbear",
      "discord": "thatlonelybugbear#4394",
      "ko-fi": "https://ko-fi.com/thatlonelybugbear"
    }
  ],
  "esmodules": ["scripts/bases-main.mjs"],
  "styles": [
    "styles/bases-status-layout.css",
    "styles/bases-status-filter.css",
    "styles/bases-status-system-overrides.css"
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    },
    {
      "lang": "it",
      "name": "Italiano",
      "path": "lang/it.json"
    },
    {
      "lang": "pt-BR",
